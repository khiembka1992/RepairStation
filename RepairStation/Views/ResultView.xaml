<UserControl x:Class="AI_AOI.Views.ResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:imb="clr-namespace:Andrew.Controls"
             Background="{StaticResource AppScreenBackgroundBrush}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="1" Grid.Column="0">
                <TextBlock x:Name="tbInformation"
                        Style="{StaticResource AppHeaderTextStyle}"
                        FontSize="20"
                        Text="Alarmed Component Statistics 0 / 0 / 0 / 0  Barcode -  Rail -  Line -"/>
            </Border>
            <Border BorderBrush="Gray" BorderThickness="1" Grid.Column="1">
                <TextBlock x:Name="tbRemain"
                            Grid.Column="1"
                            Style="{StaticResource AppHeaderTextStyle}"
                            FontSize="20"
                            Text="Statistics"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <imb:ImageBox x:Name="ibImage" BorderBrush="Gray" BorderThickness="1" Grid.Column="0"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="Gray" BorderThickness="1" Grid.Row="0">
                    <TextBlock x:Name="tbStatistics"
                               Foreground="#F2F2F2"
                               FontSize="25"
                               TextWrapping="Wrap"/>
                </Border>
                <Border BorderBrush="Gray" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Button x:Name="tbStatus"
                            Style="{StaticResource AppBigStatusButtonStyle}"
                            Content="WATTING"
                            Foreground="Yellow"/>
                        <TextBlock x:Name="tbStatusShortcut"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="0,0,16,12"
                                Foreground="#E6E6E6"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="(Enter)"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
