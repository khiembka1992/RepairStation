<Window x:Class="AI_AOI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="Login"
        Height="180"
        Width="250"
        Background="{StaticResource AppScreenBackgroundBrush}"
        Foreground="{StaticResource AppTextPrimaryBrush}">
    <Border Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Margin="0,0,0,16"
                       FontWeight="SemiBold"
                       Text="Repair Station Login"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="User"/>
            <TextBox x:Name="tbUser"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,0,0,10"
                     Style="{StaticResource AppFilterTextBoxStyle}"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Password"/>
            <PasswordBox x:Name="pbPassword"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,0,10"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource AppInputBackgroundBrush}"
                         Foreground="{StaticResource AppTextSecondaryBrush}"
                         BorderBrush="#666666"/>

            <StackPanel Grid.Row="3"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button Width="55"
                        Margin="0,0,8,0"
                        Content="Login"
                        Click="LoginButton_Click"
                        IsDefault="True"
                        Style="{StaticResource AppToolbarButtonStyle}"/>
                <Button Width="60"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        IsCancel="True"
                        Style="{StaticResource AppToolbarButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
