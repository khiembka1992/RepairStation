<Window x:Class="AI_AOI.Views.SoftwareSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="Software Settings"
        Height="560"
        Width="800"
        Background="{StaticResource AppScreenBackgroundBrush}"
        Foreground="{StaticResource AppTextPrimaryBrush}">
    <Grid>
        <Border Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="HOLLY_AOI_REPAIR_AI"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,12,8" Text="{Binding HOLLY_AOI_REPAIR_AIConnectionString}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="HOLLY_AOI_REPAIR"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,8" Text="{Binding HOLLY_AOI_REPAIRConnectionString}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Image Scale"/>
                <TextBox Grid.Row="2" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding ImageScale}" Style="{StaticResource AppFilterTextBoxStyle}"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Rectangle Thickness"/>
                <TextBox Grid.Row="3" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding RectangleThickness}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Font Size"/>
                <TextBox Grid.Row="4" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding FontSize}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="History Data Root"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,12,8" Text="{Binding HistoryDataRootPath}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Image Data Root"/>
                <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,12,8" Text="{Binding ImageDataRootPath}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Offset NG Root"/>
                <TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,12,8" Text="{Binding OffsetNgRootPath}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Offset OK Root"/>
                <TextBox Grid.Row="8" Grid.Column="1" Margin="0,0,12,8" Text="{Binding OffsetOkRootPath}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Text="Shopfloor Export Root"/>
                <TextBox Grid.Row="9" Grid.Column="1" Margin="0,0,12,8" Text="{Binding ShopfloorExportRootPath}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Text="Repeated Lock Count"/>
                <TextBox Grid.Row="10" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding RepeatedComponentLockCount}" Style="{StaticResource AppFilterTextBoxStyle}"/>

                <TextBlock Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Text="Alarm Types Red (CSV)"/>
                <TextBox Grid.Row="11" Grid.Column="1" Margin="0,0,12,0" Text="{Binding AlarmTypesRedText}" Style="{StaticResource AppFilterTextBoxStyle}" ToolTip="Example:Missing,No Solder,Bridge"/>
            </Grid>
        </Border>
    </Grid>
</Window>
