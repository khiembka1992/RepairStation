<Window x:Class="AI_AOI.Views.RepeatedComponentLockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Title="Program Locked"
        Height="300"
        Width="520"
        Closing="Window_Closing"
        Background="{StaticResource AppScreenBackgroundBrush}"
        Foreground="{StaticResource AppTextPrimaryBrush}">
    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Margin="0,0,0,16"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="Yellow"
                       TextWrapping="Wrap"
                       Text="Program locked because a component appears repeatedly."/>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"
                       Text="{Binding LockMessage}"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Password"/>
            <PasswordBox x:Name="pbPassword"
                         Grid.Row="2"
                         Grid.Column="1"
                         Height="30"
                         Margin="0,0,0,16"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource AppInputBackgroundBrush}"
                         Foreground="{StaticResource AppTextSecondaryBrush}"
                         BorderBrush="#666666"/>

            <Button Grid.Row="3"
                    Grid.Column="1"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Right"
                    Content="Unlock"
                    IsDefault="True"
                    Click="UnlockButton_Click"
                    Style="{StaticResource AppToolbarButtonStyle}"/>
        </Grid>
    </Border>
</Window>
