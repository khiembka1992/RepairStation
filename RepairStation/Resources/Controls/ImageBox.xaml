<UserControl x:Class="Andrew.Controls.ImageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      
             mc:Ignorable="d" 
             FontSize="11"
             
             PreviewKeyDown="UserControl_PreviewKeyDown"
             PreviewMouseWheel="UserControl_PreviewMouseWheel"
             PreviewKeyUp="UserControl_PreviewKeyUp"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Loaded"
             >

        <ScrollViewer x:Name="scroll"
                  ScrollChanged="scroll_ScrollChanged"
                  HorizontalScrollBarVisibility="Auto" 
                  VerticalScrollBarVisibility="Auto"
                  ClipToBounds="True" PreviewMouseDown="imb_PreviewMouseDown"
             PreviewMouseUp="imb_PreviewMouseUp"
             PreviewMouseMove="imb_PreviewMouseMove">
            <ScrollViewer.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="mnZoomIn" Click="mnZoomIn_Click" Header="Zoom In">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A3;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mnZoomOut" Click="mnZoomOut_Click" Header="Zoom Out">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71F;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mnFillScreen" Click="mnFillScreen_Click" Header="Fill Screen">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE740;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mnResetSelection" Click="mnResetSelection_Click" Header="Reset Selection">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mnReset" Click="mnReset_Click" Header="Reset Zoom">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="mnBulkSeparator" Visibility="Collapsed"/>
                    <MenuItem x:Name="mnAllOk" Click="mnAllOk_Click" Header="All OK" Visibility="Collapsed">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mnAllNg" Click="mnAllNg_Click" Header="All NG" Visibility="Collapsed">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ScrollViewer.ContextMenu>
        <Grid x:Name="grid">

                <Image x:Name="imb" Source="{Binding ImageSource, RelativeSource={RelativeSource  AncestorType=UserControl}}" 
                       Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor">
                </Image>

            <Rectangle x:Name="rect"
                Stroke="Yellow" VerticalAlignment="Top"
                HorizontalAlignment="Left" StrokeThickness="1"
                Width="0" Height="0" Visibility="Hidden">
            </Rectangle>
            <Rectangle x:Name="subrect"
                Stroke="Yellow" VerticalAlignment="Top"
                HorizontalAlignment="Left" StrokeThickness="1"
                Width="0" Height="0" Visibility="Hidden">
            </Rectangle>
            <Canvas x:Name="canvas"/>
        </Grid>
        </ScrollViewer>
</UserControl>
