<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppScreenBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="White"/>
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="White"/>

    <Style x:Key="AppHeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppHeaderBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AppToolbarButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}"/>
        <Setter Property="Background" Value="#595959"/>
        <Setter Property="BorderBrush" Value="#424242"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppFilterTextBoxStyle" TargetType="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="#666666"/>
    </Style>

    <Style x:Key="AppSummaryTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#EDEDED"/>
    </Style>

    <Style x:Key="AppDataGridStyle" TargetType="DataGrid">
        <Setter Property="AlternatingRowBackground" Value="#35383D"/>
        <Setter Property="RowBackground" Value="#333333"/>
        <Setter Property="Foreground" Value="#E8E8E8"/>
        <Setter Property="Background" Value="#333333"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3A3D42"/>
                    <Setter Property="Foreground" Value="#F2F2F2"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppBigStatusButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="220"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
</ResourceDictionary>
